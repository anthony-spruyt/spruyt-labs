{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "description": "Disable kubernetes manager for runner sidecar (version managed via kustomize images transformer)",
      "matchManagers": [
        "kubernetes"
      ],
      "matchPackageNames": [
        "n8nio/runners"
      ],
      "pinDigests": false,
      "enabled": false
    },
    {
      "description": "Use semver for n8n docker images to ignore pre-release tags (beta, nightly, etc)",
      "matchPackageNames": [
        "n8nio/**"
      ],
      "matchDatasources": [
        "docker"
      ],
      "versioning": "semver"
    },
    {
      "description": "Coder uses two-channel releases (mainline/stable); 30-day delay + ignore pre-releases",
      "matchPackageNames": [
        "coder"
      ],
      "matchDatasources": [
        "helm"
      ],
      "minimumReleaseAge": "30 days",
      "ignoreUnstable": true
    },
    {
      "description": "Disable dockerfile manager for golang (ARG interpolation breaks updates; custom.regex manager handles these via annotations)",
      "matchManagers": [
        "dockerfile"
      ],
      "matchPackageNames": [
        "golang"
      ],
      "enabled": false
    }
  ]
}
