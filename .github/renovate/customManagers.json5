{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  customManagers: [
    {
      customType: "regex",
      description: ["Process renovate-annotated dependencies."],
      managerFilePatterns: [
        "(^|/)talos/(?:[^/]+/)*[^/]+\\.ya?ml$",
        "(^|/)cluster/(?:[^/]+/)*[^/]+\\.ya?ml$",
      ],
      matchStrings: [
        "#\\s*renovate:(?:\\s+(?:datasource=(?<datasource>\\S+)|depName=(?<depName>\\S+)|packageName=(?<packageName>\\S+))){1,}\\s*\\n(?:[^\\n]*chart:\\s*(?<chartName>[^\\s\"']+)[^\\n]*\\n|[^\\n]*\\n){0,3}?[^\\S\\n]*(?<prefix>(?:version|talosVersion|kubernetesVersion):\\s*)(?<currentValue>[^\\s\"']+)",
        "#\\s*renovate:(?:\\s+(?:datasource=(?<datasource>\\S+)|depName=(?<depName>\\S+)|packageName=(?<packageName>\\S+))){1,}[^\\n]*\\n(?:[^\\n]*\\n)?[^\\S\\n]*(?:-\\s*)?(?<prefix>[^\\n]*/)(?<currentValue>(?:v|\\d)[^/\\s\"']+)",
      ],
      depNameTemplate: "{{#if depName}}{{{depName}}}{{else}}{{#if packageName}}{{{packageName}}}{{else}}{{#if chartName}}{{{chartName}}}{{/if}}{{/if}}{{/if}}",
      packageNameTemplate: "{{#if depName}}{{{depName}}}{{else}}{{#if packageName}}{{{packageName}}}{{else}}{{#if chartName}}{{{chartName}}}{{/if}}{{/if}}{{/if}}",
      datasourceTemplate: "{{#if datasource}}{{{datasource}}}{{else}}{{#if chartName}}helm{{else}}github-releases{{/if}}{{/if}}",
    },
  ],
}
