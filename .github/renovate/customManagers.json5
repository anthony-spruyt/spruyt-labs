{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  // IMPORTANT: Renovate uses RE2 regex engine, NOT JavaScript RegExp.
  // RE2 does NOT support: backreferences (\1, \k<name>), lookahead (?=), lookbehind (?<=)
  // RE2 DOES support: named groups (?<name>), non-greedy quantifiers (*?, +?, {n,m}?)
  // Key difference: With alternation in quantified groups like (?:A|B){1,}, only the
  // LAST match's capture groups are retained. This means patterns like:
  //   (?:datasource=(?<ds>\S+)|depName=(?<dep>\S+)){1,}
  // will only capture whichever group matched LAST, not both.
  // Solution: Use separate matchStrings for each parameter ordering.
  // Test patterns at: https://regex101.com (select Golang flavor for RE2 compatibility)
  // Docs: https://docs.renovatebot.com/modules/manager/regex/
  customManagers: [
    {
      customType: "regex",
      description: ["Process renovate-annotated dependencies."],
      managerFilePatterns: [
        "/(^|/)talos/(?:[^/]+/)*[^/]+\\.ya?ml$/",
        "/(^|/)cluster/(?:[^/]+/)*[^/]+\\.ya?ml$/",
      ],
      matchStrings: [
        // Version field: # renovate: depName=X datasource=Y \n key: v1.2.3
        // The ".+ " matches "talosVersion:" then space before version
        "depName=(?<depName>\\S+) datasource=(?<datasource>\\S+)\\n.+ (?<currentValue>(v|\\d)\\S+)",
        // URL path: # renovate: depName=X datasource=Y \n .../v1.2.3/...
        "depName=(?<depName>\\S+) datasource=(?<datasource>\\S+)\\n.+/(?<currentValue>(v|\\d)[^/]+)",
      ],
      datasourceTemplate: "{{#if datasource}}{{{datasource}}}{{else}}github-releases{{/if}}",
    },
  ],
}
