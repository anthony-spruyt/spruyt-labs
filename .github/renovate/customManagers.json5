{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  customManagers: [
    {
      customType: "regex",
      description: ["Process renovate-annotated dependencies."],
      managerFilePatterns: ["//talos/.+\\.ya?ml$//", "//cluster/.+\\.ya?ml$//"],
      matchStrings: [
        "depName=(?<depName>\\S+) datasource=(?<datasource>\\S+)\\s*\\n\\s*(?<prefix>.+?)(?<currentValue>(v|\\d)[^\\s/]+)",
        "depName=(?<depName>\\S+) datasource=(?<datasource>\\S+)\\s*\\n\\s*.+/(?<currentValue>(v|\\d)[^/]+)",
      ],
      datasourceTemplate: "{{#if datasource}}{{{datasource}}}{{else}}github-releases{{/if}}",
    },
  ],
}
