{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  //
  // ====== RENOVATE REGEX MANAGER REFERENCE ======
  //
  // 1. managerFilePatterns MUST be wrapped in forward slashes: "/pattern/"
  //    WRONG: "(^|/)talos/.+\\.ya?ml$"
  //    RIGHT: "/(^|/)talos/.+\\.ya?ml$/"
  //
  // 2. Renovate uses RE2 regex engine, NOT JavaScript RegExp.
  //    - NOT supported: backreferences (\1, \k<name>), lookahead (?=), lookbehind (?<=)
  //    - Supported: named groups (?<name>), non-greedy quantifiers (*?, +?, {n,m}?)
  //
  // 3. Alternation in quantified groups only retains LAST match's captures:
  //    (?:datasource=(?<ds>\S+)|depName=(?<dep>\S+)){1,}
  //    ^ This will only capture whichever group matched LAST, not both!
  //    Solution: Use separate matchStrings for each parameter ordering.
  //
  // 4. Annotation format standard: "# renovate: depName=X datasource=Y"
  //    Always use depName before datasource for consistency.
  //
  // Test patterns: https://regex101.com (select Golang flavor for RE2)
  // Docs: https://docs.renovatebot.com/modules/manager/regex/
  //
  customManagers: [
    {
      customType: "regex",
      description: ["Process renovate-annotated dependencies."],
      managerFilePatterns: [
        "/(^|/)talos/(?:[^/]+/)*[^/]+\\.ya?ml$/",
        "/(^|/)cluster/(?:[^/]+/)*[^/]+\\.ya?ml$/",
      ],
      matchStrings: [
        // Version field: # renovate: depName=X datasource=Y \n key: v1.2.3
        // The ".+ " matches "talosVersion:" then space before version
        "depName=(?<depName>\\S+) datasource=(?<datasource>\\S+)\\n.+ (?<currentValue>(v|\\d)\\S+)",
        // URL path: # renovate: depName=X datasource=Y \n .../v1.2.3/...
        "depName=(?<depName>\\S+) datasource=(?<datasource>\\S+)\\n.+/(?<currentValue>(v|\\d)[^/]+)",
      ],
      datasourceTemplate: "{{#if datasource}}{{{datasource}}}{{else}}github-releases{{/if}}",
    },
  ],
}
