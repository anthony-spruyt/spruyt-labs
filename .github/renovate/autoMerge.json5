{
  "packageRules": [
    {
      matchDatasources: [
        "docker"
      ],
      automerge: true,
      automergeType: "branch",
      requiredStatusChecks: null,
      matchUpdateTypes: [
        "minor",
        "patch"
      ],
      matchPackageNames: [],
    },
    {
      "description": "Auto merge GitHub Actions",
      "matchManagers": [
        "github-actions"
      ],
      "matchDatasources": [
        "github-tags"
      ],
      "automerge": true,
      "automergeType": "branch",
      "requiredStatusChecks": null,
      "matchUpdateTypes": [
        "minor",
        "patch"
      ]
    }
  ]
}
