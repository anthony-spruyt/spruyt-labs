{
  packageRules: [
    {
      matchUpdateTypes: ["patch", "digest", "pin"],
      matchFileNames: ["^cluster/apps/.*"],
      automerge: true,
      platformAutomerge: true,
    },
    {
      matchManagers: ["github-actions"],
      matchUpdateTypes: ["minor"],
      automerge: true,
      platformAutomerge: true,
    },
    {
      matchPackageNames: ["fluxcd/*", "ghcr.io/fluxcd/*"],
      matchUpdateTypes: ["minor"],
      automerge: true,
      platformAutomerge: true,
    },
  ],
}
