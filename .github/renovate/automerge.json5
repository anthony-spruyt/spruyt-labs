{
  packageRules: [
    {
      description: "Automerge patch updates",
      matchUpdateTypes: ["patch", "digest", "pin"],
      automerge: true,
      platformAutomerge: true,
    },
    {
      description: "Automerge GitHub Actions and pre-commit minor updates",
      matchManagers: ["github-actions", "pre-commit"],
      matchUpdateTypes: ["minor"],
      automerge: true,
      platformAutomerge: true,
    },
    {
      description: "Automerge Terraform provider minor updates",
      matchManagers: ["terraform"],
      matchDatasources: ["terraform-provider"],
      matchUpdateTypes: ["minor"],
      automerge: true,
      platformAutomerge: true,
    },
    {
      description: "Disable automerge for calver packages (date-based versions are not true semver patches)",
      matchCurrentVersion: "/^20\\d{2}\\./",
      automerge: false,
    },
    {
      description: "Disable automerge for rook-ceph during RMA (issue #236)",
      matchPackagePatterns: ["^(ghcr\\.io/)?rook(/|-)ceph"],
      automerge: false,
    },
    {
      description: "Disable automerge for openclaw",
      matchPackagePatterns: ["^(ghcr\\.io/)?openclaw"],
      automerge: false,
    },
  ],
}
