{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  description: [
    "Regex managers covering Talos manifests, Taskfiles, shell scripts, and miscellaneous YAML where Renovate needs explicit capture groups.",
  ],
  customManagers: [
    {
      customType: "regex",
      managerFilePatterns: ["/(^|/)talos/.+\\.ya?ml$/"],
      matchStrings: [
        "#\\s*renovate:(?:\\s+(?:datasource=(?<datasource>\\S+)|depName=(?<depName>\\S+)|packageName=(?<packageName>\\S+))){1,}\\s*\\n[^\\S\\n]*(?<prefix>(?:talosVersion|kubernetesVersion|version):\\s*)(?<currentValue>[^\\s\"']+)",
        "-\\s+#\\s*renovate:(?:\\s+(?:datasource=(?<datasource>\\S+)|depName=(?<depName>\\S+)|packageName=(?<packageName>\\S+))){1,}\\s*\\n[^\\S\\n]*(?<currentValue>https?://[^\\s\"']+)",
      ],
      depNameTemplate: "{{#if depName}}{{{depName}}}{{else}}{{{packageName}}}{{/if}}",
      packageNameTemplate: "{{#if depName}}{{{depName}}}{{else}}{{{packageName}}}{{/if}}",
      datasourceTemplate: "{{#if datasource}}{{{datasource}}}{{else}}github-releases{{/if}}",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/(^|/)talos/helmfile/.+\\.ya?ml$/"],
      matchStrings: [
        "chart:\\s*(?<ociPrefix>oci://)?(?<chartPath>[\\w./-]+)\\s*\\n[^\\S\\n]*version:\\s*(?<currentValue>[^\\s\"']+)",
      ],
      depNameTemplate: "{{{chartPath}}}",
      datasourceTemplate: "{{#if ociPrefix}}oci{{else}}helm{{/if}}",
      packageNameTemplate: "{{{chartPath}}}",
    },
    {
      customType: "regex",
      managerFilePatterns: [
        "/(^|/)cluster/flux/meta/repositories/oci/.+\\.ya?ml$/",
      ],
      matchStrings: [
        'url:\\s*oci://(?<depNamePath>[^\\s]+)[^\\S\\n]*\\n(?:[\\s\\S]*?)?ref:\\s*\\n[^\\S\\n]*tag:\\s*"?(?<currentValue>[^"\\s]+)"?',
      ],
      depNameTemplate: "{{{depNamePath}}}",
      datasourceTemplate: "oci",
      packageNameTemplate: "{{{depNamePath}}}",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/(^|/)cluster/.+\\.ya?ml$/"],
      matchStrings: [
        "#\\s*renovate:(?:\\s+(?:datasource=(?<datasource>\\S+)|depName=(?<depName>\\S+)|packageName=(?<packageName>\\S+))){1,}\\s*\\n[^\\S\\n]*(?<prefix>[\\w.-]+:\\s*)(?<currentValue>[^\\s\"']+)",
        '(?<artifactPrefix>artifact:\\s*"?)oci://(?<depNamePath>[^:"\\s]+)(?::|@)(?<currentValue>[^"\\s]+)"?',
      ],
      depNameTemplate: "{{#if depName}}{{{depName}}}{{else}}{{#if depNamePath}}{{{depNamePath}}}{{else}}{{{packageName}}}{{/if}}{{/if}}",
      packageNameTemplate: "{{#if depName}}{{{depName}}}{{else}}{{#if depNamePath}}{{{depNamePath}}}{{else}}{{{packageName}}}{{/if}}{{/if}}",
      datasourceTemplate: "{{#if datasource}}{{{datasource}}}{{else}}{{#if artifactPrefix}}oci{{else}}github-releases{{/if}}{{/if}}",
    },
    {
      customType: "regex",
      managerFilePatterns: [
        "/(^|/)\\.taskfiles/.+\\.(ya?ml|tmpl\\.ya?ml)$/",
        "/(^|/)\\.taskfiles/.+/scripts/.+\\.(sh|bash)$/",
      ],
      matchStrings: [
        "(?<prefix>image:\\s*)(?<depName>[^:\\s]+):(?<currentValue>[^\\s\"']+)",
        "(?<depName>(?:ghcr|docker\\.io|quay\\.io|registry\\.k8s\\.io)[^:\\s]+):(?<currentValue>[^\\s\"']+)",
      ],
      depNameTemplate: "{{{depName}}}",
      packageNameTemplate: "{{{depName}}}",
      datasourceTemplate: "docker",
    },
  ],
}
