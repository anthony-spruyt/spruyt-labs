{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  description: ["Custom datasources for non-standard package sources"],
  customDatasources: {
    // ArtifactHub Headlamp plugins datasource
    // API path: /api/v1/packages/headlamp/<repo>/<plugin>
    // depName format: <repo>/<plugin> (e.g., headlamp-plugins/headlamp_flux)
    "artifacthub-headlamp": {
      defaultRegistryUrlTemplate: "https://artifacthub.io/api/v1/packages/headlamp/{{packageName}}",
      format: "json",
      // Transform ArtifactHub response to Renovate format
      // ArtifactHub returns: { "available_versions": [{ "version": "0.5.0", ... }] }
      transformTemplates: [
        '{ "releases": [$map(available_versions, function($v) { { "version": $v.version } })] }',
      ],
    },
  },
}
