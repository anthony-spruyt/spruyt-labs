{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  description: [
    "Shared Helm configuration for Renovate. Consolidates registry discovery for HTTP and OCI chart sources referenced throughout the cluster and Talos manifests.",
  ],
  "helm-values": {
    managerFilePatterns: ["/(^|/)cluster/.+/(values|release)\\.ya?ml$/"],
  },
  packageRules: [
    {
      matchDatasources: ["helm"],
      matchPackageNames: ["app-template"],
      registryUrls: ["https://bjw-s-labs.github.io/helm-charts/"],
    },
    {
      matchDatasources: ["helm"],
      matchPackageNames: ["cloudnative-pg"],
      registryUrls: ["https://cloudnative-pg.github.io/charts"],
    },
    {
      matchDatasources: ["helm"],
      matchPackageNames: ["external-secrets"],
      registryUrls: ["https://charts.external-secrets.io"],
    },
    {
      matchDatasources: ["helm"],
      matchPackageNames: ["authentik"],
      registryUrls: ["https://charts.goauthentik.io"],
    },
    {
      matchDatasources: ["helm"],
      matchPackageNames: ["cert-manager"],
      registryUrls: ["https://charts.jetstack.io/"],
    },
    {
      matchDatasources: ["helm"],
      matchPackageNames: ["cilium", "cilium/cilium"],
      packageName: "cilium",
      registryUrls: ["https://helm.cilium.io"],
    },
    {
      matchDatasources: ["helm"],
      matchPackageNames: ["traefik"],
      registryUrls: ["https://helm.traefik.io/traefik"],
    },
    {
      matchDatasources: ["helm"],
      matchPackageNames: ["minecraft-bedrock", "minecraft-server"],
      registryUrls: ["https://itzg.github.io/minecraft-server-charts"],
    },
    {
      matchDatasources: ["helm"],
      matchPackageNames: ["external-dns"],
      registryUrls: ["https://kubernetes-sigs.github.io/external-dns"],
    },
    {
      matchDatasources: ["helm"],
      matchPackageNames: ["kubelet-csr-approver"],
      registryUrls: ["https://postfinance.github.io/kubelet-csr-approver"],
    },
    {
      matchDatasources: ["helm"],
      matchPackageNames: ["reloader"],
      registryUrls: ["https://stakater.github.io/stakater-charts"],
    },
    {
      matchDatasources: ["helm"],
      matchPackageNames: ["velero"],
      registryUrls: ["https://vmware-tanzu.github.io/helm-charts"],
    },
    {
      matchDatasources: ["helm"],
      matchPackageNames: ["valkey"],
      registryUrls: ["https://valkey.io/valkey-helm/"],
    },
    {
      matchDatasources: ["helm"],
      matchPackageNames: ["plugin-barman-cloud"],
      registryUrls: ["https://cloudnative-pg.github.io/charts"],
    },
  ],
}
