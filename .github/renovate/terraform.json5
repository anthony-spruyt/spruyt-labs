{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  description: [
    "Terraform configuration for Renovate. Enables provider, module, and runtime updates across infra/terraform workspaces.",
  ],
  terraform: {
    managerFilePatterns: [
      "(^|/)infra/terraform/.+\\.tf$",
      "(^|/)infra/terraform/.+\\.tfvars(\\.json)?$",
      "(^|/)infra/terraform/.terraform.lock.hcl$",
    ],
  },
  packageRules: [
    {
      matchManagers: ["terraform"],
      matchDatasources: ["terraform-provider"],
      separateMinorPatch: true,
      minimumReleaseAge: "3 days",
      labels: ["renovate/terraform", "dep/provider"],
    },
    {
      matchManagers: ["terraform"],
      matchDatasources: ["terraform-module"],
      separateMinorPatch: true,
      labels: ["renovate/terraform", "dep/module"],
    },
    {
      matchManagers: ["terraform"],
      matchDatasources: ["terraform-version"],
      labels: ["renovate/terraform", "dep/runtime"],
    },
  ],
}
