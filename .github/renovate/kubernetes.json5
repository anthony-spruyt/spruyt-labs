{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  description: [
    "Centralized Flux, Kubernetes and Helm values manager configuration.",
  ],
  flux: {
    fileMatch: ["(^|/)cluster/.+\\.ya?ml$"],
  },
  "helm-values": {
    fileMatch: [
      "(^|/)cluster/.+/(values(\\.\\w+)?|values\\.ya?ml)$",
      "(^|/)cluster/.+/(release|helmrelease)\\.ya?ml$",
      "(^|/)talos/helmfile/.+\\.ya?ml$",
    ],
  },
  kubernetes: {
    fileMatch: ["(^|/)cluster/.+\\.ya?ml$", "(^|/)talos/.+\\.ya?ml$"],
  },
}
