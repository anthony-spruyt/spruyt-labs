{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    "docker:enableMajor",
    ":dependencyDashboard",
    ":disableRateLimiting",
    ":semanticCommits",
    ":enablePreCommit",
    ":separatePatchReleases",
    "github>anthony-spruyt/spruyt-labs//.github/renovate/disabledDatasources.json5",
    "github>anthony-spruyt/spruyt-labs//.github/renovate/customManagers.json5",
    "github>anthony-spruyt/spruyt-labs//.github/renovate/groups.json5",
    "github>anthony-spruyt/spruyt-labs//.github/renovate/kubernetes.json5",
    "github>anthony-spruyt/spruyt-labs//.github/renovate/terraform.json5",
    "github>anthony-spruyt/spruyt-labs//.github/renovate/regex-managers.json5",
    "github>anthony-spruyt/spruyt-labs//.github/renovate/customDatasources.json5",
    "github>anthony-spruyt/spruyt-labs//.github/renovate/automerge.json5",
  ],
  enabled: true,
  ignorePaths: ["talos/helmfile"],
  dependencyDashboardTitle: "Renovate Dashboard",
  suppressNotifications: ["prIgnoreNotification"],
  commitBodyTable: true,
  rebaseWhen: "conflicted",
  enabledManagers: [
    "custom.regex",
    "dockerfile",
    "flux",
    "github-actions",
    "helm-values",
    "kubernetes",
    "pre-commit",
    "terraform",
    "devcontainer",
  ],
  packageRules: [
    {
      matchDatasources: ["helm"],
      separateMinorPatch: true,
      ignoreDeprecated: true,
    },
    {
      matchDatasources: ["docker"],
      enabled: true,
      commitMessageTopic: "container image {{depName}}",
      commitMessageExtra: "to {{#if isSingleVersion}}v{{{newVersion}}}{{else}}{{{newValue}}}{{/if}}",
      matchUpdateTypes: ["major", "minor", "patch"],
    },
    {
      matchDatasources: ["docker", "oci"],
      pinDigests: false,
    },
    {
      matchDatasources: ["docker", "oci"],
      matchUpdateTypes: ["major"],
      labels: ["renovate/image", "dep/major"],
    },
    {
      matchDatasources: ["docker", "oci"],
      matchUpdateTypes: ["minor"],
      labels: ["renovate/image", "dep/minor"],
    },
    {
      matchDatasources: ["docker", "oci"],
      matchUpdateTypes: ["patch"],
      labels: ["renovate/image", "dep/patch"],
    },
    {
      matchDatasources: ["helm"],
      matchUpdateTypes: ["major"],
      labels: ["renovate/helm", "dep/major"],
    },
    {
      matchDatasources: ["helm"],
      matchUpdateTypes: ["minor"],
      labels: ["renovate/helm", "dep/minor"],
    },
    {
      matchDatasources: ["helm"],
      matchUpdateTypes: ["patch"],
      labels: ["renovate/helm", "dep/patch"],
    },
    {
      matchManagers: ["github-actions"],
      labels: ["renovate/github-actions"],
      minimumReleaseAge: "2 days",
    },
    {
      matchManagers: ["terraform"],
      labels: ["renovate/terraform"],
      separateMinorPatch: true,
    },
    {
      matchManagers: ["custom.regex"],
      matchFileNames: [".taskfiles/**"],
      labels: ["renovate/taskfile"],
      pinDigests: false,
    },
    {
      matchManagers: ["custom.regex"],
      matchFileNames: ["talos/**"],
      labels: ["renovate/talos"],
      minimumReleaseAge: "3 days",
    },
  ],
}
