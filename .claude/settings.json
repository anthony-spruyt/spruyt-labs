{
  "permissions": {
    "deny": [
      "Read(./talos/clusterconfig/**)",
      "Read(./**/*.sops.*)",
      "Read(./.gitattributes)",
      "Read(./.gitleaksignore)",
      "Read(./LICENSE)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./**/*id_rsa*)",
      "Read(./**/*id_ed25519*)",
      "Read(./**/*id_ecdsa*)",
      "Read(./**/*.credentials)",
      "Read(./**/*credentials.json)",
      "Read(./**/*kubeconfig*)",
      "Read(./**/*.htpasswd)",
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Bash(sops -d:*)",
      "Bash(sops --decrypt:*)",
      "Bash(sops exec-env:*)",
      "Bash(sops exec-file:*)",
      "Bash(base64 -d:*)",
      "Bash(base64 --decode:*)",
      "Bash(printenv:*)",
      "Bash(age -d:*)",
      "Bash(age --decrypt:*)",
      "Bash(git push:*)",
      "Bash(git commit --amend:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "file_path=$(jq -r '.tool_input.file_path // .tool_input.notebook_path' < /dev/stdin); npx prettier --write \"$file_path\" 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "github@claude-plugins-official": true
  }
}
