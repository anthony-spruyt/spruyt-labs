{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "respectGitignore": true,
  "cleanupPeriodDays": 20,
  "env": {
    "ANTHROPIC_API_KEY": "",
    "API_TIMEOUT_MS": "30000000",
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false",
    "CLAUDE_CODE_ATTRIBUTION_HEADER": "0",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1",
    "CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1",
    "CLAUDE_CODE_ENABLE_AWAY_SUMMARY": "0",
    "CLAUDE_CODE_ENABLE_BACKGROUND_PLUGIN_REFRESH": "0",
    "CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY": "1",
    "CLAUDE_CODE_MAX_RETRIES": "100",
    "CLAUDE_CODE_SYNC_PLUGIN_INSTALL": "1",
    "CLAUDE_CODE_SYNC_PLUGIN_INSTALL_TIMEOUT_MS": "120000",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "deny": [
      "Read(./**/*id_rsa*)",
      "Read(./**/*id_ed25519*)",
      "Read(./**/*id_ecdsa*)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./**/*.p12)",
      "Read(./**/*.pfx)",
      "Read(./**/*.jks)",
      "Read(./**/*.keystore)",
      "Read(./**/*.credentials)",
      "Read(./**/*credentials.json)",
      "Read(./**/.aws/credentials)",
      "Read(./**/.kube/config)",
      "Read(./**/*kubeconfig*)",
      "Read(./**/*.htpasswd)",
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./**/*.sops.*)",
      "Read(./**/.docker/config.json)",
      "Read(./**/.config/gh/hosts.yml)",
      "Read(./**/.npmrc)",
      "Read(./**/.pypirc)",
      "Read(./**/.netrc)",
      "Read(./**/.vault-token)",
      "Read(./**/.ssh/config)",
      "Read(~/.ssh/*)",
      "Read(~/.ssh/**/*)",
      "Read(~/.aws/credentials)",
      "Read(~/.kube/config)",
      "Read(~/.docker/config.json)",
      "Read(~/.config/gh/hosts.yml)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",
      "Read(~/.netrc)",
      "Read(~/.vault-token)",
      "Read(~/.gnupg/*)",
      "Read(~/.gnupg/**/*)",
      "Read(~/.password-store/*)",
      "Read(~/.password-store/**/*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "file_path=$(jq -r '.tool_input.file_path // .tool_input.notebook_path' < /dev/stdin); case \"$file_path\" in *.md) mdformat \"$file_path\" 2>/dev/null || true ;; *) npx prettier --write \"$file_path\" 2>/dev/null || true ;; esac"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c 'input=$(cat); project_dir=$(echo \"$input\" | jq -r \".workspace.project_dir\"); bash \"$project_dir/.claude/statusline.sh\" <<< \"$input\"'"
  },
  "enabledPlugins": {
    "hookify-plus@aspruyt-plugins": true,
    "security-hooks@aspruyt-plugins": true,
    "best-practices@aspruyt-plugins": true,
    "superpowers@claude-plugins-official": false,
    "caveman@caveman": true,
    "agentmemory@agentmemory": false,
    "context7@claude-plugins-official": false,
    "claude-code-setup@claude-plugins-official": false,
    "claude-md-management@claude-plugins-official": false,
    "code-review@claude-plugins-official": false,
    "feature-dev@claude-plugins-official": false,
    "hookify@claude-plugins-official": false,
    "plugin-dev@claude-plugins-official": false,
    "security-guidance@claude-plugins-official": false
  },
  "extraKnownMarketplaces": {
    "agentmemory": {
      "source": {
        "source": "github",
        "repo": "rohitg00/agentmemory"
      },
      "autoUpdate": true
    },
    "aspruyt-plugins": {
      "source": {
        "source": "github",
        "repo": "anthony-spruyt/claude-plugins"
      },
      "autoUpdate": true
    },
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      },
      "autoUpdate": true
    }
  },
  "viewMode": "default",
  "feedbackSurveyRate": 0,
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "fastMode": false,
  "showClearContextOnPlanAccept": true,
  "autoUpdatesChannel": "latest",
  "channelsEnabled": false,
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true
}
