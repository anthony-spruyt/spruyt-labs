{
  "$schema": "./openclaw-schema.json",
  "logging": {
    "level": "info",
    "consoleLevel": "info",
    "consoleStyle": "compact",
    "redactSensitive": "tools"
  },
  "browser": {
    "enabled": true,
    "defaultProfile": "default",
    "profiles": {
      "default": {
        "cdpUrl": "http://localhost:9222",
        "color": "#4285F4"
      }
    }
  },
  "auth": {
    "profiles": {
      "anthropic:manual": {
        "provider": "anthropic",
        "mode": "token"
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-opus-4-6"
      },
      "workspace": "/home/node/.openclaw/workspace",
      "userTimezone": "Australia/Melbourne",
      "memorySearch": {
        "enabled": true,
        "provider": "openai",
        "model": "text-embedding-3-small",
        "query": {
          "hybrid": {
            "enabled": true,
            "vectorWeight": 0.7,
            "textWeight": 0.3,
            "candidateMultiplier": 4,
            "mmr": {
              "enabled": true,
              "lambda": 0.7
            },
            "temporalDecay": {
              "enabled": true,
              "halfLifeDays": 30
            }
          }
        },
        "cache": {
          "enabled": true,
          "maxEntries": 50000
        }
      },
      "timeoutSeconds": 600,
      "maxConcurrent": 1
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "identity": {
          "name": "Skynet",
          "emoji": "💀",
          "avatar": "avatar.png",
          "theme": "Dry, slightly menacing, but ultimately helpful. Think Terminator meets butler."
        }
      }
    ]
  },
  "tools": {
    "profile": "full",
    "web": {
      "search": {
        "enabled": true
      },
      "fetch": {
        "enabled": true
      }
    },
    "fs": {
      "workspaceOnly": false
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "allowFrom": {
      "discord": ["user:249242152318664709"]
    }
  },
  "session": {
    "scope": "per-sender",
    "reset": {
      "mode": "idle",
      "idleMinutes": 60
    },
    "store": "/home/node/.openclaw/sessions"
  },
  "channels": {
    "discord": {
      "enabled": true,
      "groupPolicy": "allowlist",
      "dm": {
        "enabled": false
      },
      "guilds": {
        "257529418187145216": {
          "requireMention": true,
          "channels": {
            "1473506635656990862": {
              "allow": true,
              "requireMention": false
            }
          }
        }
      }
    }
  },
  "discovery": {
    "mdns": {
      "mode": "off"
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "controlUi": {
      "allowInsecureAuth": true
    }
  },
  "skills": {
    "allowBundled": [
      "github",
      "gh-issues",
      "healthcheck",
      "mcporter",
      "skill-creator",
      "weather"
    ],
    "entries": {
      "mcp-context7": {
        "enabled": true
      },
      "mcp-hass": {
        "enabled": true
      },
      "mcp-n8n": {
        "enabled": true
      },
      "ontology": {
        "enabled": true
      },
      "humanizer": {
        "enabled": true
      }
    }
  },
  "plugins": {
    "entries": {
      "whatsapp": {
        "enabled": false
      },
      "discord": {
        "enabled": true
      }
    }
  }
}
