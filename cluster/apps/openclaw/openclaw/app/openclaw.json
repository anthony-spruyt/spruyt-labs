{
  "$schema": "./openclaw-schema.json",
  "update": {
    "channel": "stable"
  },
  "auth": {
    "profiles": {
      "anthropic:manual": {
        "provider": "anthropic",
        "mode": "token"
      },
      "openai:default": {
        "provider": "openai",
        "mode": "api_key"
      }
    }
  },
  "logging": {
    "level": "info",
    "consoleLevel": "info",
    "consoleStyle": "compact",
    "redactSensitive": "tools"
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-sonnet-4-6",
        "fallbacks": ["openai/gpt-5-mini"]
      },
      "models": {
        "anthropic/claude-haiku-4-5": {
          "alias": "haiku"
        },
        "anthropic/claude-sonnet-4-6": {
          "alias": "sonnet",
          "params": {
            "context1m": true
          }
        },
        "anthropic/claude-opus-4-6": {
          "alias": "opus",
          "params": {
            "context1m": true
          }
        }
      },
      "workspace": "/home/node/.openclaw/workspace",
      "userTimezone": "Australia/Melbourne",
      "memorySearch": {
        "enabled": true,
        "sources": ["memory", "sessions"],
        "experimental": {
          "sessionMemory": true
        },
        "provider": "openai",
        "model": "text-embedding-3-small",
        "query": {
          "hybrid": {
            "enabled": true,
            "vectorWeight": 0.7,
            "textWeight": 0.3,
            "candidateMultiplier": 4,
            "mmr": {
              "enabled": true,
              "lambda": 0.7
            },
            "temporalDecay": {
              "enabled": true,
              "halfLifeDays": 30
            }
          }
        },
        "cache": {
          "enabled": true,
          "maxEntries": 50000
        }
      },
      "contextTokens": 1000000,
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "3h",
        "keepLastAssistants": 3,
        "softTrimRatio": 0.3,
        "hardClearRatio": 0.5,
        "minPrunableToolChars": 50000,
        "hardClear": {
          "enabled": true,
          "placeholder": "[Old tool result content cleared]"
        },
        "tools": { "deny": ["browser", "canvas"] }
      },
      "compaction": {
        "mode": "safeguard",
        "maxHistoryShare": 0.5,
        "reserveTokensFloor": 24000,
        "memoryFlush": {
          "enabled": true,
          "softThresholdTokens": 40000,
          "prompt": "Distill this session to memory/YYYY-MM-DD.md. Focus on decisions, state changes, lessons, blockers. If nothing worth storing: NO_FLUSH",
          "systemPrompt": "Extract only what is worth remembering. No fluff."
        }
      },
      "heartbeat": {
        "model": "anthropic/claude-haiku-4-5"
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      },
      "timeoutSeconds": 600
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "identity": {
          "name": "Skynet",
          "emoji": "💀",
          "avatar": "avatar.png",
          "theme": "Dry, slightly menacing, but ultimately helpful. Think Terminator meets butler."
        }
      },
      {
        "id": "monitor",
        "model": {
          "primary": "anthropic/claude-haiku-4-5",
          "fallbacks": ["openai/gpt-5-nano"]
        }
      },
      {
        "id": "researcher",
        "model": {
          "primary": "anthropic/claude-sonnet-4-6",
          "fallbacks": ["openai/gpt-5-mini"]
        }
      },
      {
        "id": "communicator",
        "model": {
          "primary": "anthropic/claude-opus-4-6",
          "fallbacks": ["openai/gpt-5.2"]
        }
      },
      {
        "id": "coordinator",
        "model": {
          "primary": "anthropic/claude-opus-4-6",
          "fallbacks": ["openai/gpt-5.2"]
        }
      },
      {
        "id": "sre",
        "model": {
          "primary": "anthropic/claude-sonnet-4-6",
          "fallbacks": ["openai/gpt-5-mini"]
        }
      }
    ]
  },
  "browser": {
    "enabled": true,
    "defaultProfile": "default",
    "profiles": {
      "default": {
        "cdpUrl": "http://localhost:9222",
        "color": "#4285F4"
      }
    }
  },
  "tools": {
    "profile": "full",
    "web": {
      "search": {
        "enabled": true
      },
      "fetch": {
        "enabled": true
      }
    },
    "fs": {
      "workspaceOnly": false
    }
  },
  "messages": {
    "ackReactionScope": "group-mentions"
  },
  "commands": {
    "ownerDisplay": "raw",
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "allowFrom": {
      "discord": ["user:249242152318664709"]
    }
  },
  "session": {
    "scope": "per-sender",
    "reset": {
      "mode": "idle",
      "idleMinutes": 60
    },
    "store": "/home/node/.openclaw/sessions"
  },
  "channels": {
    "discord": {
      "enabled": true,
      "streamMode": "off",
      "groupPolicy": "allowlist",
      "dmPolicy": "allowlist",
      "allowFrom": ["249242152318664709"],
      "dm": {
        "enabled": true
      },
      "guilds": {
        "257529418187145216": {
          "requireMention": true,
          "users": ["249242152318664709"],
          "channels": {
            "1473506635656990862": {
              "allow": true,
              "requireMention": false
            }
          }
        }
      },
      "threadBindings": {
        "enabled": true,
        "idleHours": 72,
        "maxAgeHours": 0
      }
    }
  },
  "discovery": {
    "mdns": {
      "mode": "off"
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "$${OPENCLAW_GATEWAY_TOKEN}"
    },
    "controlUi": {
      "allowedOrigins": ["https://openclaw.${EXTERNAL_DOMAIN}"],
      "dangerouslyDisableDeviceAuth": true
    }
  },
  "skills": {
    "allowBundled": [
      "github",
      "gh-issues",
      "healthcheck",
      "mcporter",
      "skill-creator",
      "weather"
    ],
    "entries": {
      "mcp-context7": {
        "enabled": true
      },
      "mcp-hass": {
        "enabled": true
      },
      "mcp-n8n": {
        "enabled": true
      },
      "ontology": {
        "enabled": true
      },
      "humanizer": {
        "enabled": true
      }
    }
  },
  "plugins": {
    "entries": {
      "whatsapp": {
        "enabled": false
      },
      "discord": {
        "enabled": true
      }
    }
  },
  "hooks": {
    "enabled": true,
    "token": "$${OPENCLAW_HOOKS_TOKEN}",
    "allowedAgentIds": ["sre"],
    "mappings": [
      {
        "id": "alertmanager",
        "match": {
          "path": "alertmanager"
        },
        "action": "agent",
        "agentId": "sre",
        "sessionKey": "hook:sre:{{groupKey}}",
        "messageTemplate": "Alertmanager webhook received.\n\nStatus: {{status}}\nGroup: {{groupLabels}}\nCommon Labels: {{commonLabels}}\nCommon Annotations: {{commonAnnotations}}\n\nFirst alert: {{alerts[0].labels.alertname}} ({{alerts[0].labels.severity}}): {{alerts[0].annotations.description}}\n\nTriage this alert. The full alerts array is in the webhook payload.",
        "deliver": true,
        "channel": "discord"
      }
    ]
  }
}
