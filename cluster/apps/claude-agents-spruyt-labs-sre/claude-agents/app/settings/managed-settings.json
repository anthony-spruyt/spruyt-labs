{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "ANTHROPIC_API_KEY": "",
    "ENABLE_TOOL_SEARCH" : "true",
    "API_TIMEOUT_MS": "30000000",
    "CLAUDE_CODE_ATTRIBUTION_HEADER" : "0",
    "CLAUDE_CODE_MAX_RETRIES": "100",
    "CLAUDE_CODE_SYNC_PLUGIN_INSTALL": "1",
    "CLAUDE_CODE_SYNC_PLUGIN_INSTALL_TIMEOUT_MS": "120000",
    "CLAUDE_CODE_DISABLE_OFFICIAL_MARKETPLACE_AUTOINSTALL": "1",
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1",
    "CLAUDE_CODE_ENABLE_AWAY_SUMMARY": "0",
    "CLAUDE_CODE_ENABLE_BACKGROUND_PLUGIN_REFRESH": "0",
    "CLAUDE_CODE_SKIP_PROMPT_HISTORY": "1",
    "DISABLE_AUTOUPDATER": "1",
    "DISABLE_UPDATES": "1",
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "0"
  },
  "permissions": {
    "deny": [
    ]
  },
  "enabledPlugins": {
    "hookify-plus@aspruyt-plugins": true,
    "security-hooks@aspruyt-plugins": true,
    "best-practices@aspruyt-plugins": true,
    "agentmemory@agentmemory": true,
    "context7@claude-plugins-official": false,
    "claude-code-setup@claude-plugins-official": false,
    "claude-md-management@claude-plugins-official": false,
    "code-review@claude-plugins-official": false,
    "feature-dev@claude-plugins-official": false,
    "hookify@claude-plugins-official": false,
    "plugin-dev@claude-plugins-official": false,
    "security-guidance@claude-plugins-official": false
  },
  "strictKnownMarketplaces": [
    {
      "source": "github",
      "repo": "anthony-spruyt/claude-plugins"
    },
    {
      "source": "github",
      "repo": "JuliusBrussee/caveman"
    },
    {
      "source": "github",
      "repo": "rohitg00/agentmemory"
    }
  ],
  "extraKnownMarketplaces": {
    "agentmemory": {
      "autoUpdate": true,
      "source": {
        "source": "github",
        "repo": "rohitg00/agentmemory"
      }
    },
    "aspruyt-plugins": {
      "autoUpdate": true,
      "source": {
        "source": "github",
        "repo": "anthony-spruyt/claude-plugins"
      }
    },
    "caveman": {
      "autoUpdate": true,
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  }
}
