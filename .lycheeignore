# GitHub rate-limits unauthenticated requests (429 Too Many Requests)
https://github.com/.*
https://raw.githubusercontent.com/.*

# GitHub API URLs require authentication and can't be validated
https://api.github.com/.*

# VS Code site returns 403 to automated link checkers
https://code.visualstudio.com/.*

# VS Code Marketplace (intermittent 503s)
https://marketplace.visualstudio.com/

# LAN server URLs use private .lan domains with shell variable substitution
.*\.lan/.*

# Internal MCP server hostname (not publicly accessible)
https://litellm/

# Localhost URLs are not reachable in CI/lint environments
http://localhost.*
https://localhost.*
http://127\.0\.0\.1.*
https://127\.0\.0\.1.*

# Schema store times out intermittently in CI
https://json\.schemastore\.org/.*


# Object storage and internal protocols
s3:*
oci:*
ssh:*

# Kubernetes internal services (service.namespace format)
.*\.[a-z0-9-]+/
.*svc.*

# Internal/LAN URLs
.*192.168.*

# Truncated URLs from ${VARIABLE} substitution (e.g., https://app/)
https?://[a-z0-9-]+/$
