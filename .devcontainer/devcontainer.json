{
  "$schema": "https://raw.githubusercontent.com/devcontainers/spec/main/schemas/devContainer.schema.json",
  "name": "Ubuntu",
  "image": "mcr.microsoft.com/devcontainers/base:jammy",
  "runArgs": [
    "--env-file",
    "${localEnv:HOME}/.secrets/.env"
  ],
  "mounts": [
    "source=${localEnv:HOME}/.ssh/agent.sock,target=/ssh-agent,type=bind",
    "source=${localEnv:HOME}/.ssh/allowed_signers,target=/home/vscode/.ssh/allowed_signers,type=bind,readonly",
    "source=${localEnv:HOME}/.ssh/known_hosts,target=/home/vscode/.ssh/known_hosts,type=bind,readonly",
    "source=${localEnv:HOME}/.claude,target=/home/vscode/.claude,type=bind",
    "source=${localEnv:HOME}/.gitconfig,target=/home/vscode/.gitconfig,type=bind,readonly",
    "source=${localEnv:HOME}/.secrets/.terraform.d,target=/home/vscode/.terraform.d,type=bind,readonly",
    "source=${localEnv:HOME}/.secrets,target=/home/vscode/.secrets,type=bind,readonly",
    "source=${localEnv:HOME}/.secrets/talosconfig,target=/home/vscode/.secrets/talosconfig,type=bind"
  ],
  "containerEnv": {
    "SSH_AUTH_SOCK": "/ssh-agent"
  },
  "features": {
    "ghcr.io/devcontainers-extra/features/pre-commit": {},
    "ghcr.io/devcontainers/features/github-cli": {},
    "ghcr.io/devcontainers/features/docker-in-docker": {},
    "ghcr.io/devcontainers/features/node": {},
    "ghcr.io/devcontainers/features/python": {},
    "ghcr.io/devcontainers-extra/features/sops": {},
    "ghcr.io/eitsupi/devcontainer-features/jq-likes": {
      "yqVersion": "latest"
    },
    "ghcr.io/devcontainers/features/terraform": {},
    "ghcr.io/devcontainers-extra/features/renovate-cli": {}
  },
  "initializeCommand": "bash ${localWorkspaceFolder}/.devcontainer/initialize.sh",
  "postCreateCommand": "bash -lc \"cd ${containerWorkspaceFolder} && ./.devcontainer/post-create.sh\"",
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "bierner.markdown-mermaid",
        "blueglassblock.better-json5",
        "esbenp.prettier-vscode",
        "mhutchie.git-graph",
        "redhat.vscode-yaml",
        "github.vscode-github-actions",
        "golang.go",
        "hashicorp.terraform",
        "task.vscode-task",
        "tim-koehler.helm-intellisense"
      ]
    }
  },
  "portsAttributes": {
    "3333": {
      "label": "Capacitor",
      "onAutoForward": "openBrowser"
    }
  }
}
