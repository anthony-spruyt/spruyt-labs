{
  "name": "Ubuntu",
  "image": "mcr.microsoft.com/devcontainers/base:jammy",
  "features": {
    "ghcr.io/devcontainers-extra/features/sops": {},
    "ghcr.io/devcontainers-extra/features/talosctl": {
      "version": "1.10.7"
    },
    "ghcr.io/devcontainers-extra/features/helmfile": {},
    "ghcr.io/devcontainers/features/kubectl-helm-minikube": {
      "version": "1.33.4"
    },
    "ghcr.io/eitsupi/devcontainer-features/jq-likes": {
      "yqVersion": "latest"
    },
    "ghcr.io/devcontainers-extra/features/pre-commit": {},
    "ghcr.io/devcontainers/features/github-cli": {},
    "ghcr.io/rio/features/kustomize": {},
    "ghcr.io/audacioustux/devcontainers/cilium": {},
    "ghcr.io/devcontainers/features/terraform": {}
  },
  "postCreateCommand": "bash -lc \"cd ${containerWorkspaceFolder} && ./.devcontainer/post-create.sh\"",
  "customizations": {
    "vscode": {
      "extensions": [
        "task.vscode-task",
        "tim-koehler.helm-intellisense",
        "redhat.vscode-yaml",
        "mhutchie.git-graph",
        "blueglassblock.better-json5",
        "esbenp.prettier-vscode",
        "kilocode.kilo-code",
        "hashicorp.terraform"
      ]
    }
  },
  "portsAttributes": {
    "3333": {
      "label": "Capacitor",
      "onAutoForward": "openBrowser"
    }
  },
  "containerEnv": {
    "SOPS_AGE_KEY_FILE": "/workspaces/spruyt-labs/secrets/age.key",
    "KUBECONFIG": "/workspaces/spruyt-labs/secrets/kubeconfig",
    "TALOSCONFIG": "/workspaces/spruyt-labs/secrets/talosconfig"
  }
}
