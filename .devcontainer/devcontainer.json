{
  "name": "Ubuntu",
  "image": "mcr.microsoft.com/devcontainers/base:jammy",
  "runArgs": ["--env-file", "${localEnv:HOME}/.secrets/.env"],
  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind",
    "source=${localEnv:HOME}/.ssh,target=/home/vscode/.ssh,type=bind",
    "source=${localEnv:HOME}/.secrets/.terraform.d,target=/home/vscode/.terraform.d,type=bind",
    "source=${localEnv:HOME}/.secrets,target=/workspaces/spruyt-labs/.secrets,type=bind",
    "source=${localEnv:HOME}/.kilocode,target=/workspaces/spruyt-labs/.kilocode,type=bind"
  ],
  "features": {
    "ghcr.io/devcontainers-extra/features/sops": {},
    "ghcr.io/devcontainers-extra/features/talosctl": {
      "version": "1.11.5"
    },
    "ghcr.io/devcontainers-extra/features/helmfile": {},
    "ghcr.io/devcontainers/features/kubectl-helm-minikube": {
      "version": "1.34.2"
    },
    "ghcr.io/eitsupi/devcontainer-features/jq-likes": {
      "yqVersion": "latest"
    },
    "ghcr.io/devcontainers-extra/features/pre-commit": {},
    "ghcr.io/devcontainers/features/github-cli": {},
    "ghcr.io/rio/features/kustomize": {},
    "ghcr.io/audacioustux/devcontainers/cilium": {},
    "ghcr.io/devcontainers/features/terraform": {},
    "ghcr.io/devcontainers/features/docker-in-docker": {},
    "ghcr.io/devcontainers/features/node": {
      "version": "22"
    }
  },
  "postCreateCommand": "bash -lc \"cd ${containerWorkspaceFolder} && ./.devcontainer/post-create.sh\"",
  "customizations": {
    "vscode": {
      "extensions": [
        "task.vscode-task",
        "tim-koehler.helm-intellisense",
        "redhat.vscode-yaml",
        "mhutchie.git-graph",
        "blueglassblock.better-json5",
        "esbenp.prettier-vscode",
        "kilocode.kilo-code",
        "hashicorp.terraform"
      ]
    }
  },
  "portsAttributes": {
    "3333": {
      "label": "Capacitor",
      "onAutoForward": "openBrowser"
    }
  }
}
