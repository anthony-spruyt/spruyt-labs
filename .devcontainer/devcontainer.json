{
  "$schema": "https://raw.githubusercontent.com/devcontainers/spec/main/schemas/devContainer.schema.json",
  "name": "devcontainer-common",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "NEXUS_URL": "${localEnv:NEXUS_URL}"
    }
  },
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "containerUser": "vscode",
  "remoteUser": "vscode",
  "runArgs": [
    "--security-opt",
    "seccomp=${localWorkspaceFolder}/.devcontainer/podman-seccomp.json",
    "--device",
    "/dev/fuse",
    "--env-file",
    "${localEnv:HOME}/.secrets/.env.common",
    "--env-file",
    "${localEnv:HOME}/.secrets/.env.spruyt-labs"
  ],
  "mounts": [
    "source=${localEnv:HOME}/.secrets/.gitignore,target=/home/vscode/.secrets/.gitignore,type=bind,readonly",
    "source=${localEnv:HOME}/.ssh/agent.sock,target=/ssh-agent,type=bind",
    "source=${localEnv:HOME}/.claude,target=/home/vscode/.claude,type=bind",
    "source=${localWorkspaceFolderBasename}-containers,target=/var/lib/containers,type=volume",
    "source=${localEnv:HOME}/.secrets/.terraform.d,target=/home/vscode/.terraform.d,type=bind,readonly",
    "source=${localEnv:HOME}/.secrets/age.key,target=/home/vscode/.secrets/age.key,type=bind,readonly",
    "source=${localEnv:HOME}/.secrets/bgp-65000.conf,target=/home/vscode/.secrets/bgp-65000.conf,type=bind,readonly",
    "source=${localEnv:HOME}/.secrets/kubeconfig,target=/home/vscode/.secrets/kubeconfig,type=bind,readonly",
    "source=${localEnv:HOME}/.secrets/talosconfig,target=/home/vscode/.secrets/talosconfig,type=bind"
  ],
  "features": {
    "ghcr.io/devcontainers/features/go": {
      "version": "1.26.3"
    },
    "ghcr.io/devcontainers/features/terraform": {
      "version": "1.15.5"
    },
    "ghcr.io/devcontainers-extra/features/renovate-cli": {
      "version": "43.205.3"
    },
    "ghcr.io/devcontainers-extra/features/sops": {
      "version": "3.13.1"
    },
    "ghcr.io/eitsupi/devcontainer-features/jq-likes": {
      "jqVersion": "1.8.1",
      "yqVersion": "4.53.2",
      "gojqVersion": "0.12.19"
    }
  },
  "initializeCommand": "bash ${localWorkspaceFolder}/.devcontainer/initialize.sh",
  "postCreateCommand": "bash -lc \"cd ${containerWorkspaceFolder} && devcontainer-post-create\"",
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "bierner.markdown-mermaid",
        "blueglassblock.better-json5",
        "esbenp.prettier-vscode",
        "mhutchie.git-graph",
        "redhat.vscode-yaml",
        "github.vscode-github-actions",
        "golang.go",
        "hashicorp.terraform",
        "jetmartin.bats",
        "task.vscode-task",
        "tim-koehler.helm-intellisense"
      ]
    }
  },
  "portsAttributes": {
    "3333": {
      "label": "Capacitor",
      "onAutoForward": "openBrowser"
    }
  }
}
