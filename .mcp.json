{
  "mcpServers": {
    "litellm": {
      "type": "http",
      "url": "https://litellm.${EXTERNAL_DOMAIN}/mcp",
      "headers": {
        "x-litellm-api-key": "Bearer ${ANTHROPIC_AUTH_TOKEN}"
      }
    },
    "cclsp": {
      "type": "stdio",
      "command": "cclsp",
      "env": {
        "CCLSP_CONFIG_PATH": "/workspaces/spruyt-labs/.claude/cclsp.json"
      }
    }
  }
}
