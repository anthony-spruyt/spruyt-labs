{
  "mcpServers": {
    "bravesearch": {
      "type": "http",
      "url": "https://brave-search-mcp.lan.${EXTERNAL_DOMAIN}/mcp",
      "headers": {
        "X-API-KEY": "${BRAVE_SEARCH_MCP_API_KEY}"
      }
    },
    "cclsp": {
      "type": "stdio",
      "command": "cclsp",
      "env": {
        "CCLSP_CONFIG_PATH": "/workspaces/spruyt-labs/.claude/cclsp.json"
      }
    },
    "victoriametrics": {
      "type": "http",
      "url": "https://mcp-vm.lan.${EXTERNAL_DOMAIN}/mcp",
      "headers": {
        "X-API-KEY": "${VM_MCP_API_KEY}"
      }
    },
    "n8n": {
      "type": "http",
      "url": "https://n8n-mcp.lan.${EXTERNAL_DOMAIN}/mcp",
      "headers": {
        "X-API-KEY": "${N8N_MCP_API_KEY}"
      }
    }
  }
}
