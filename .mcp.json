{
  "mcpServers": {
    "victoriametrics": {
      "type": "http",
      "url": "https://mcp-vm.lan.${EXTERNAL_DOMAIN}/mcp",
      "headers": {
        "X-API-KEY": "${VM_MCP_API_KEY}"
      }
    },
    "kubernetes": {
      "type": "http",
      "url": "https://kubectl-mcp.lan.${EXTERNAL_DOMAIN}/mcp",
      "headers": {
        "X-API-KEY": "${KUBECTL_MCP_API_KEY}"
      }
    },
    "cclsp": {
      "type": "stdio",
      "command": "cclsp",
      "env": {
        "CCLSP_CONFIG_PATH": "/workspaces/spruyt-labs/.claude/cclsp.json"
      }
    }
  }
}
