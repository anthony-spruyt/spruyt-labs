{
  "files.exclude": {
    ".devcontainer": false,
    ".github": false,
    ".taskfiles": false,
    ".secrets": false,
    ".sops.yaml": true,
    ".gitattributes": true,
    ".gitleaksignore": true,
    ".gitignore": true,
    ".pre-commit-config.yaml": true,
    "LICENSE": true,
    "Taskfile.yml": true,
    ".kilocode": false,
    ".kilocodeignore": true,
    "talos/clusterconfig": false,
    "**/.terraform": true,
    "**/.terraform.lock.hcl": true
  },
  "search.exclude": {
    "**/*.secret.*": true,
    "**/temp/**": true,
    "**/.secrets/**": true
  },
  "files.autoSave": "afterDelay",
  "files.autoSaveWorkspaceFilesOnly": true,
  "editor.formatOnSave": true,
  "editor.codeActions.triggerOnFocusChange": false,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "prettier.configPath": ".github/linters/.prettierrc.yaml",
  "prettier.ignorePath": ".github/linters/.prettierignore",
  "explorer.sortOrder": "type",
  "editor.tabSize": 2,
  "[terraform]": {
    "editor.defaultFormatter": "hashicorp.terraform"
  }
}
