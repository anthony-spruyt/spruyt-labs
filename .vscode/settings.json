{
  "files.exclude": {
    ".devcontainer": false,
    ".github": false,
    ".taskfiles": false,
    ".capacitor": false,
    "secrets": false,
    ".sops.yaml": false,
    ".gitattributes": false,
    ".gitleaksignore": false,
    ".gitignore": false,
    ".pre-commit-config.yaml": false,
    "LICENSE": false,
    "Taskfile.yml": false,
    ".kilocodeignore": false,
    "talos/clusterconfig": false,
    "**/.terraform": false,
    "**/.terraform.lock.hcl": false
  },
  "search.exclude": {
    "**/*.secret.*": true,
    "**/temp/**": true,
    "**/secrets/**": true
  },
  "files.autoSave": "afterDelay",
  "files.autoSaveWorkspaceFilesOnly": true,
  "editor.formatOnSave": true,
  "editor.codeActions.triggerOnFocusChange": false,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "prettier.configPath": ".github/linters/.prettierrc.yaml",
  "prettier.ignorePath": ".github/linters/.prettierignore",
  "explorer.sortOrder": "type"
}
