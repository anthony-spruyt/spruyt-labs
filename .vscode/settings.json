{
  "files.exclude": {
    ".devcontainer": true,
    ".github": true,
    ".taskfiles": true,
    "capacitor": true,
    "secrets": false,
    ".sops.yaml": true,
    ".gitattributes": true,
    ".gitleaksignore": true,
    ".gitignore": true,
    ".pre-commit-config.yaml": true,
    "LICENSE": true,
    "Taskfile.yml": true,
    ".kilocodeignore": true,
    "talos/clusterconfig": false
  },
  "search.exclude": {
    "**/*.secret.*": true,
    "**/temp/**": true,
    "**/secrets/**": true
  },
  "files.autoSave": "afterDelay",
  "files.autoSaveWorkspaceFilesOnly": true,
  "editor.formatOnSave": true,
  "editor.codeActions.triggerOnFocusChange": false,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "prettier.configPath": ".github/linters/.prettierrc.yaml",
  "prettier.ignorePath": ".github/linters/.prettierignore"
}
